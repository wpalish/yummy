{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/format-py.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo; echo \"Session complete $(date +%H:%M). Changes:\"; git -C \"$CLAUDE_PROJECT_DIR\" diff --stat 2>/dev/null | tail -20 || echo \"нет git-изменений\"'",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'command -v osascript >/dev/null 2>&1 && osascript -e \"display notification \\\"${CLAUDE_NOTIFICATION:-Claude Code}\\\" with title \\\"Yummy · Claude Code\\\"\" || true'",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(.venv/bin/python -m pytest*)",
      "Bash(.venv/bin/python -m py_compile*)",
      "Bash(make test*)",
      "Bash(make docs*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(curl -s http://127.0.0.1:*)",
      "Bash(curl -s http://localhost:*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /*)",
      "Bash(git push * --force *)",
      "Read(.env)",
      "Read(./.env)"
    ]
  }
}
