# Yummy — переменные окружения для продакшена (скопируй в настройки хостинга)

# ОБЯЗАТЕЛЬНО: секрет подписи JWT (сгенерируй: python -c "import secrets;print(secrets.token_hex(32))")
YUMMY_SECRET_KEY=

# ОБЯЗАТЕЛЬНО: отдельный ключ envelope encryption для MFA secrets (не равен JWT key)
YUMMY_DATA_KEY=

# ОБЯЗАТЕЛЬНО в проде: включает fail-fast проверку конфигурации.
# Private API защищён JWT всегда, независимо от этой переменной.
YUMMY_ENV=production

# CORS только для public/Bearer API, без credentials. Production browser session
# всегда same-origin; Pages — изолированная демка.
YUMMY_CORS_ORIGINS=https://wpalish.github.io

# Host-header allowlist (без схемы/порта), через запятую.
YUMMY_ALLOWED_HOSTS=yummy-astana.onrender.com

# Максимальный JSON body; сервер ограничивает диапазон 1 KiB–1 MiB.
YUMMY_MAX_REQUEST_BYTES=65536

# Для нескольких backend replicas: Redis atomic distributed rate limits.
REDIS_URL=redis://localhost:6379/0
YUMMY_RATE_LIMIT_KEY=

# Transactional email. Для production: resend + HTTPS public URL.
YUMMY_EMAIL_MODE=resend
RESEND_API_KEY=
YUMMY_EMAIL_FROM=Yummy <noreply@example.kz>
YUMMY_PUBLIC_URL=https://example.kz

# Stripe Checkout. Начинай только с test mode; live keys — через Secret Manager.
YUMMY_PAYMENT_MODE=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=kzt

# Опционально: токен бота от @BotFather — включает вход через Telegram
TELEGRAM_BOT_TOKEN=

# Production: PostgreSQL; schema управляется только Alembic.
DATABASE_URL=postgresql://yummy:password@localhost:5432/yummy
YUMMY_DB_POOL_MIN=1
YUMMY_DB_POOL_MAX=10
YUMMY_DB_POOL_TIMEOUT=5
YUMMY_DB_STATEMENT_TIMEOUT_MS=5000
YUMMY_DB_LOCK_TIMEOUT_MS=2000
YUMMY_DB_IDLE_TX_TIMEOUT_MS=10000
# Dev/test fallback без DATABASE_URL:
YUMMY_DB_PATH=./spasibox.db

# Опционально: ключ Anthropic — включает AI-описания боксов и AI-модерацию
# отзывов (без ключа обе фичи работают на детерминированном фолбэке/эвристике,
# не выключаются). Также используется tools/generate_pitch.py.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
