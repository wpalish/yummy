# Yummy — переменные окружения для продакшена (скопируй в настройки хостинга)

# ОБЯЗАТЕЛЬНО: секрет подписи JWT (сгенерируй: python -c "import secrets;print(secrets.token_hex(32))")
YUMMY_SECRET_KEY=

# ОБЯЗАТЕЛЬНО в проде: включает серверную защиту партнёрских/админских эндпоинтов
YUMMY_ENFORCE_AUTH=1

# Email владельца: регистрация с этим email получает роль admin
YUMMY_ADMIN_EMAILS=alisher.nursain@gmail.com

# CORS: с каких доменов разрешены запросы к API (через запятую)
YUMMY_CORS_ORIGINS=https://wpalish.github.io

# Host allowlist (анти Host-Header-Injection). Пусто → "*" (демо/локально).
# В проде укажи домен API через запятую. Swagger /docs выключается автоматически
# при YUMMY_ENFORCE_AUTH=1.
YUMMY_ALLOWED_HOSTS=yummy-astana.onrender.com

# Лимит тела запроса, байт (анти-DoS). По умолчанию 65536 (64 KiB) — с запасом.
YUMMY_MAX_BODY_BYTES=65536

# Опционально: токен бота от @BotFather — включает вход через Telegram,
# рассылку «новый бокс» и интерактивного бота (@yummy_astana_bot: /start /boxes /stop).
TELEGRAM_BOT_TOKEN=

# Секрет webhook бота (любая случайная строка: python -c "import secrets;print(secrets.token_hex(16))").
# Задать И на бэкенде, И зарегистрировать webhook:
#   python -m app.telegram_bot set-webhook
# Пусто → бот в polling-режиме (подписчики ловятся при рассылке), webhook off.
TELEGRAM_WEBHOOK_SECRET=

# База публичных ссылок в Telegram-сообщениях (диплинк на бокс) и в инвайтах
YUMMY_PUBLIC_URL=https://wpalish.github.io/yummy/

# --- Демо vs прод -----------------------------------------------------------
# Режим оплаты:
#   demo     — оплата имитируется, QR сразу (пилот; в UI честно подписано)
#   disabled — платёжного провайдера нет → покупка НЕДОСТУПНА (503) вместо
#              фейкового «оплачено»; платный бокс нельзя опубликовать без
#              активного мерчант-аккаунта; демо-отзывы скрыты
# (значение kaspi появится вместе с реальной Kaspi-интеграцией)
YUMMY_PAYMENT_MODE=demo

# Посев демо-заведений при пустой БД. В проде (YUMMY_ENFORCE_AUTH=1) НИКОГДА не
# сеется автоматически: пустая БД → пустой каталог, а не выдуманные кофейни.
# Ставить 1 только чтобы принудительно засеять демо (локально/стенд).
YUMMY_DEMO_SEED=

# Публичный Telegram-канал-витрина: новые боксы авто-постятся туда с кнопкой.
# Формат: @username (публичный) или -100xxxxxxxxxx (числовой id приватного).
# Бот ДОЛЖЕН быть админом канала с правом «Публикация сообщений».
# Пусто → канал выключен (остаётся личная рассылка подписчикам бота).
# Для сайта на Pages: задать этот env и пересобрать `make docs`, чтобы ссылка
# на канал попала в статику (index() на Render подставляет на лету).
YUMMY_TG_CHANNEL=

# БД: если задан DATABASE_URL — работаем на Postgres (Supabase Session pooler :5432),
# иначе SQLite по YUMMY_DB_PATH. Postgres переживает редеплои (SQLite на free Render — нет).
#   DATABASE_URL=postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=

# Путь к файлу SQLite (fallback без DATABASE_URL). На хостинге — persistent-диск,
# иначе SQLite сотрётся при каждом деплое (напр. /var/data/yummy.db)
YUMMY_DB_PATH=

# Опционально: ключ Anthropic — включает AI-описания боксов и AI-модерацию
# отзывов (без ключа обе фичи работают на детерминированном фолбэке/эвристике,
# не выключаются). Также используется tools/generate_pitch.py.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# ApiPay.kz — реальный Kaspi (YUMMY_PAYMENT_MODE=apipay). Ключи из личного кабинета apipay.kz.
APIPAY_API_KEY=
APIPAY_WEBHOOK_SECRET=
