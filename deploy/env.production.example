YUMMY_DOMAIN=example.kz
YUMMY_ENV=production
YUMMY_PUBLIC_URL=https://example.kz
YUMMY_ALLOWED_HOSTS=example.kz
YUMMY_CORS_ORIGINS=https://example.kz

DATABASE_URL=postgresql://USER:PASSWORD@SUPABASE_SESSION_POOLER:5432/postgres?sslmode=require
REDIS_URL=redis://redis:6379/0
YUMMY_REQUIRE_WORKER=1
YUMMY_DB_POOL_MIN=1
YUMMY_DB_POOL_MAX=5
YUMMY_DB_POOL_TIMEOUT=5
YUMMY_DB_STATEMENT_TIMEOUT_MS=5000
YUMMY_DB_LOCK_TIMEOUT_MS=2000
YUMMY_DB_IDLE_TX_TIMEOUT_MS=10000

YUMMY_SECRET_KEY=GENERATE_64_HEX
YUMMY_DATA_KEY=GENERATE_DIFFERENT_64_HEX
YUMMY_RATE_LIMIT_KEY=GENERATE_ANOTHER_64_HEX
YUMMY_MAX_REQUEST_BYTES=65536

YUMMY_EMAIL_MODE=resend
RESEND_API_KEY=SET_IN_SECRET_FILE
YUMMY_EMAIL_FROM=Yummy <noreply@example.kz>

# Fail-closed until an official provider is configured.
YUMMY_PAYMENT_MODE=disabled
STRIPE_CURRENCY=kzt
